source: zap_test.go
expression: stdout.String()
---
|
  name = "testdata/export/toml.http"
  timeout = "30s"
  connectionTimeout = "10s"

  [[requests]]
  name = "Everything"
  method = "PUT"
  url = "https://api.somewhere.com/items/1"
  httpVersion = "2"
  body = "{\"stuff\": \"here\"}"
  timeout = "30s"
  connectionTimeout = "10s"
  noRedirect = true
  [requests.vars]
  token = "shhh"
  [requests.headers]
  Accept = ["application/json"]
  Authorization = ["Bearer shhh"]
  Content-Type = ["application/json"]
  X-Something-Else = ["yes"]
